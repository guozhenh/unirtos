#cmakedefine CONFIG_UNIRTOS_QICFG_TCP_RETRANSCFG_FOR_QUALCOMM

/**
 * @brief QFREAD 可以读取长度最小限度平台差异，有些平台可以支持最小长度为0
 * @brief QFREAD can read minimum platform differences in length, some platforms can support a minimum length of 0

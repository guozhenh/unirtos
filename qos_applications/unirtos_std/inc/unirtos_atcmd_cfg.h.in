/**
 * @brief TCPIP ATC功能中显示真实的本地端口,而非客户默认配置的端口
 * @brief The TCPIP ATC function displays the real local port instead of the default port configured by the customer
 */
#cmakedefine CONFIG_UNIRTOS_TCPIP_SUPORT_SHOW_REAL_LOCAL_PORT

/**
 * @brief TCPIP ATC功能，qicfg="recv/ignore" qicfg="wakeup"查询显示是原样字符串，还是原始十六进制数据,默认是十六进制数据
 * @brief at+qicfg=recv/ignore Whether to display hexadecimal data
 */
#cmakedefine CONFIG_UNIRTOS_TCPIP_RECV_IGNORE_SHOW_TYPE

/**
 * @brief TCPIP ATC功能，qicfg="recv/ignore" qicfg="wakeup"查询显示是原样字符串，还是原始十六进制数据,默认是十六进制数据
 * @brief at+qicfg=wakeup Whether to display hexadecimal data
 */
#cmakedefine CONFIG_UNIRTOS_TCPIP_WAKEUP_SHOW_TYPE


 * @brief 配置FILE AT所对应的watermark的low刻度
 * @brief Set the low watermark scale corresponding to the FILE AT
 */
#cmakedefine CONFIG_UNIRTOS_FILE_WATERMARK_LOW @CONFIG_UNIRTOS_FILE_WATERMARK_LOW@

/**
 * @brief 配置FILE AT所对应的watermark的HIGH刻度
 * @brief Set a HIGH watermark for FILE AT
 */
#cmakedefine CONFIG_UNIRTOS_FILE_WATERMARK_HIGH @CONFIG_UNIRTOS_FILE_WATERMARK_HIGH@

/**
 * @brief 配置FILE AT所对应的接收watermark最大空间
 * @brief Set the maximum receiving watermark space for FILE AT
 */
#cmakedefine CONFIG_UNIRTOS_FILE_WATERMARK_MAX_LIMIT @CONFIG_UNIRTOS_FILE_WATERMARK_MAX_LIMIT@


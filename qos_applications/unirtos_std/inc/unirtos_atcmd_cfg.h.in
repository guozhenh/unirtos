/**
 * @brief 单次从watermark中取出多少数据并写入到文件中，影响文件写入速度
 * @brief Set the amount of data retrieved from the watermark at a time and written to the file affects the speed of file writing.
 */
#cmakedefine CONFIG_UNIRTOS_FILE_WRITE_ONCE_MAX_COUNT @CONFIG_UNIRTOS_FILE_WRITE_ONCE_MAX_COUNT@

/**
 * @brief 单次从文件中读取多少数据送入到watermark中去，影响数据read速度
 * @brief The amount of data read from the file at once and sent to the watermark affects the speed of data reading.
 */

CONFIG_QOSA_MBEDTLS_LIBRARY_FUNC=n
CONFIG_QOSA_MBEDTLS_SUPPORT=n
CONFIG_QOSA_CAN_SUPPORT=n
CONFIG_QOSA_VPU_SUPPORT=n
CONFIG_QOSA_CAMERA_SUPPORT=n

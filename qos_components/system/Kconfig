# If using the built-in UniRTOS library, enable the MBEDTLS3_X_X or MBEDTLS2_X_X macro definition.
# If not using the built-in UniRTOS library and directly using the platform's native mbedtls library, do not select either.
# However, the OSA_MBEDTLS_LIBRARY_FUNC macro must also be enabled.
config QOSA_MBEDTLS_LIBRARY_FUNC
    bool "mbedtls library types"
    depends on QOSA_SSL_FUNC
    default y

config QOSA_MBEDTLS3_X_X_LIBRARY_FUNC
    bool "mbedtls3_x_x library suport TLS1_3"
    depends on QOSA_SSL_FUNC
    depends on QOSA_MBEDTLS_LIBRARY_FUNC
    default n

config QOSA_MBEDTLS2_X_X_LIBRARY_FUNC
    bool "mbedtls2_28_x library suport TLS1_1 TLS1_2"
    depends on QOSA_SSL_FUNC
    depends on QOSA_MBEDTLS_LIBRARY_FUNC
    default n


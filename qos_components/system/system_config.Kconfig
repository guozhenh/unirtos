#/************************************************************************/
#/* watermark platform level configuration macro definitions             */
#/************************************************************************/
config QOSA_WATERMARK_ITEM_MERGE
    bool "watermark item merge"
    default n

#/************************************************************************/
#/* psm platform differentiation features                                */
#/************************************************************************/
config QOSA_LPM_PSM_SUPPORT_FUNC
    bool "Support for psm mode"
    default n

